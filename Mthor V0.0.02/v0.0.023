        'kkk': 'risos', 'kkkk': 'risos', 'haha': 'risos',
        'rs': 'risos', 'rsrs': 'risos',
        'aff': 'que chato', 'afff': 'que chato',
        'oxe': 'nossa', 'oxi': 'nossa', 'vixe': 'nossa',
        'tlg': 'entendeu', 'tlgd': 'entendeu', 'tendeu': 'entendeu',
        'ce': 'voce', 'num': 'nao', 'pra': 'para', 'pro': 'para o',
        'tchau': 'tchau', 'xau': 'tchau', 'ate': 'ate',
        'bjs': 'beijos', 'bj': 'beijo', 'abcs': 'abracos',
        'add': 'adicionar', 'att': 'atualizacao',
        'msg': 'mensagem', 'msm': 'mesmo', 'mt': 'muito', 'mto': 'muito',
        'amg': 'amigo', 'amgs': 'amigos', 'miga': 'amiga', 'migo': 'amigo',
        'gnt': 'gente', 'glr': 'galera', 'fml': 'familia',
        'sdd': 'saudade', 'sd': 'saudade',
        'bgl': 'negocio', 'bglh': 'negocio', 'ngc': 'negocio',
        'slc': 'nossa', 'slk': 'nossa', 'mds': 'meu deus',
        'putz': 'poxa', 'eita': 'nossa', 'vish': 'nossa',
        'cr': 'acreditar', 'crer': 'acreditar',
        'pdc': 'pode crer', 'pdp': 'pode',
        'ne?': 'nao e', 'neh?': 'nao e', 'serio?': 'serio',
        'real?': 'real', 'verdade?': 'verdade',
        'c ta bem?': 'voce esta bem', 'ta bem?': 'esta bem',
        'de boa?': 'tudo bem', 'de buenas?': 'tudo bem',
        'na paz?': 'tudo bem', 'suave?': 'tudo bem',
        'sussa?': 'tudo bem', 'joia?': 'tudo bem',
        'firme?': 'tudo bem', 'belezinha?': 'tudo bem',
        'marcha?': 'tudo bem',
        'e isso': 'ok', 'e isso ai': 'ok', 'isso ai': 'ok',
        'falou': 'tchau',
        'ate mais': 'ate logo', 'ate breve': 'ate logo',
        'abraco': 'abraco', 'abc': 'abraco', 'abrs': 'abracos',
        'lindo': 'lindo', 'linda': 'linda', 'querido': 'querido',
        'querida': 'querida', 'amor': 'amor',
        'certo?': 'ok', 'ok?': 'ok', 'okay?': 'ok',
        'mentira!': 'serio', 'serio msm?': 'serio mesmo',
        'oxente': 'nossa', 'vixe maria': 'nossa',
        'credo': 'nossa', 'cruzes': 'nossa',
        'caraca': 'nossa', 'caramba': 'nossa',
        'mete bronca': 'vamos', 'mete marcha': 'vamos',
        't+': 'ate logo', 'te mais': 'ate logo', 'inte': 'ate logo',
        # Novas adições para conversa informal
        'td': 'tudo', 'ctg': 'contigo', 'cntg': 'contigo',
        'vc ta': 'voce esta', 'c ta': 'voce esta', 'ce ta': 'voce esta',
        'cê': 'voce', 'tá': 'esta', 'tô': 'estou',
        'bão': 'bom', 'bao': 'bom', 'firmeza': 'firme',
        'suav': 'suave', 'suave?': 'tudo bem', 'db?': 'tudo bem',
        'bv': 'boa noite', 'bd': 'bom dia', 'bt': 'boa tarde'
    }
    
    # Aplica tradução de internetês
    for giria, traducao in internetes.items():
        p_limpo = p_limpo.replace(' ' + giria + ' ', ' ' + traducao + ' ')
        if p_limpo.startswith(giria + ' '):
            p_limpo = traducao + ' ' + p_limpo[len(giria)+1:]
        if p_limpo.endswith(' ' + giria):
            p_limpo = p_limpo[:len(p_limpo)-len(giria)-1] + ' ' + traducao
        if p_limpo == giria:
            p_limpo = traducao
    
    # Remove pontuação e caracteres especiais
    p_limpo = p_limpo.replace('?', '').replace('!', '').replace('.', '').replace(',', '')
    p_limpo = p_limpo.replace('  ', ' ').strip()
    
    palavras = p_limpo.split()
    
    # CORREÇÃO EXTRA: verifica "tudo e vc" / "tudo e voce"
    if len(palavras) >= 3 and palavras[0] == 'tudo' and palavras[1] == 'e' and palavras[2] in ['voce', 'vc']:
        p_limpo = 'tudo e com voce'
        palavras = p_limpo.split()
    
    # Verifica "e vc" / "e voce" sozinho
    if len(palavras) == 2 and palavras[0] == 'e' and palavras[1] in ['voce', 'vc']:
        p_limpo = 'e com voce'
        palavras = p_limpo.split()
    
    contexto_atual = "inicio"
    if len(historico_conversa) >= 2:
        contexto_atual = historico_conversa[-2].get("contexto", "inicio")
    
    tem_numero_rotina = extrair_numero_rotina(pergunta_usuario) is not None
    
    # ==================================================
    # DETECÇÃO DE ASSUNTO TÉCNICO (mais restrito)
    # ==================================================
    palavras_tecnicas = ['rotina', 'erro', 'problema', 'pedido', 'compra', 'venda', 'estoque', 
                         'fiscal', 'nota', 'nf', 'nf-e', 'nfe', 'cadastro', 'digitar', 'lançar',
                         'emitir', 'gerar', 'módulo', 'modulo', 'tela', 'campo', 'código', 'codigo',
                         'fornecedor', 'cliente', 'produto', 'winthor',
                         'atualizar', 'atualiza', 'atualização', 'atualizacao', 'base',
                         'procedure', 'procedures', 'banco', 'database', 'ambiente', 'servidor']
    
    tem_assunto_tecnico = any(p in palavras for p in palavras_tecnicas) or tem_numero_rotina
    
    # ==================================================
    # 1. SAUDAÇÕES E CONVERSA SOCIAL
    # ==================================================
    saudacoes = ['oi', 'ola', 'olá', 'hey', 'eai', 'e aí', 'bom dia', 'boa tarde', 'boa noite', 'opa', 'iae', 'salve']
    social = ['tudo bem', 'como vai', 'como está', 'como esta', 'tudo otimo', 'tudo ótimo', 'tudo certo', 
              'tudo joia', 'tudo e com voce', 'e com você', 'e com voce', 'tudo bom', 'tudo tranquilo', 
              'beleza', 'maravilha', 'otimo', 'ótimo', 'bem', 'bom',
              'tudo e vc', 'tudo e voce', 'e vc', 'e voce', 'tudo ctg', 'tudo contigo',
              'tudo em cima', 'tudo certo por aqui', 'tudo ok', 'td bem', 'td certo',
              'tudo de boa', 'tudo de boas', 'tudo suave', 'tudo sussa', 'tudo na paz',
              'tudo beleza', 'tudo joia', 'tudo firme', 'tudo tranquilo',
              'como ta', 'como tá', 'como c ta', 'como ce ta', 'como voce ta',
              'como vc ta', 'como cê tá', 'bão', 'bao', 'de boa', 'de boas',
              'na paz', 'suave', 'sussa', 'firme', 'firmeza', 'tranquilo',
              'joia', 'belezinha', 'marcha', 'como ta vc', 'como ta voce']
    agradecimentos = ['obrigado', 'obrigada', 'valeu', 'brigado', 'agradeço']
    despedidas = ['vlw', 'flw', 'tchau', 'xau', 'ate', 'inte', 'falou', 'ate mais', 'ate logo']
    
    # SAUDAÇÃO PURA (sem assunto técnico) - só se NÃO tiver "tudo bem" junto
    if any(s in p_limpo for s in saudacoes) and not tem_assunto_tecnico and len(palavras) <= 5:
        # Verifica se a saudação veio JUNTO com "tudo bem"
        tem_tudo_bem = any(p in p_limpo for p in ['tudo bem', 'tudo bom'])
        
        if tem_tudo_bem:
            # "olá tudo bem?" → responde a saudação + pergunta de volta
            historico_conversa[-1]["contexto"] = "saudacao"
            return random.choice([
                "Olá! Tudo bem sim! 😊 E você?",
                "Oi! Tudo bem! Como está você?",
                "Olá! Estou bem! Obrigado por perguntar. E você?"
            ])
        
        historico_conversa[-1]["contexto"] = "saudacao"
        if 'bom dia' in p_limpo:
            return random.choice(["Bom dia! ☀️ Tudo bem?", "Bom dia! 😊 Como posso ajudar?"])
        elif 'boa tarde' in p_limpo:
            return random.choice(["Boa tarde! 🌤️ Tudo bem?", "Boa tarde! 😊 Como posso ajudar?"])
        elif 'boa noite' in p_limpo:
            return random.choice(["Boa noite! 🌙 Tudo bem?", "Boa noite! 😊 Como posso ajudar?"])
        else:
            return random.choice(["Oi! 😊 Tudo bem?", "Olá! Como vai?", "Oi! Que bom falar com você!"])

    # SAUDAÇÃO + TÉCNICO
    if any(s in p_limpo for s in saudacoes) and tem_assunto_tecnico:
        historico_conversa[-1]["contexto"] = "tecnico"
        abertura = random.choice(["Oi! Vamos ver isso...", "Olá! Deixa eu te ajudar!", "Oi! Vou pesquisar aqui..."])
        # Remove saudação e processa
        for s in saudacoes:
            p_limpo = p_limpo.replace(s, '').strip()
        if p_limpo:
            return abertura + "\n\n" + processar_pergunta_tecnica(p_limpo)
        return abertura + "\n\n" + processar_pergunta_tecnica(pergunta_usuario)
    
    # CONVERSA SOCIAL (tudo bem?, como vai?, maravilha, etc.)
    if any(s in p_limpo for s in social) and not tem_assunto_tecnico and len(palavras) <= 6:
        historico_conversa[-1]["contexto"] = "social"
        
        # PRIMEIRO: verifica "tudo bem" e "como vai" (perguntas)
        # Depois verifica respostas ("ótimo", "bem", etc.)
        
        if any(p in p_limpo for p in ['tudo bem', 'como vai', 'como está', 'como esta']):
            if contexto_atual == "saudacao":
                # Acabou de dizer "oi", agora perguntou "tudo bem?"
                return random.choice([
                    "Tudo bem sim! 😊 E você, como está?",
                    "Estou bem! Obrigado por perguntar. E você?",
                    "Vou bem! Que bom que perguntou. Como você está?"
                ])
            elif contexto_atual == "social":
                # Já estava conversando, perguntou de novo
                return random.choice([
                    "Continuo bem! 😊 E você?",
                    "Tudo certo por aqui! O que me conta?",
                    "Estou ótimo! Em que posso ajudar?"
                ])
            else:
                return random.choice([
                    "Tudo bem sim! 😊 E você?",
                    "Estou ótimo! Como você está?",
                    "Vou bem! O que me conta?"
                ])
        
        # DEPOIS: verifica respostas positivas ("maravilha", "ótimo", "bem", "bom")
        if any(p in p_limpo for p in ['maravilha', 'otimo', 'ótimo', 'bem', 'bom', 'tudo certo', 'tudo joia', 'tudo otimo']):
            if contexto_atual == "saudacao":
                return random.choice([
                    "Que bom! 😊 Me conta, em que posso ajudar com o WinThor?",
                    "Fico feliz! Tem alguma dúvida sobre o sistema?",
                    "Ótimo saber! No que posso ser útil hoje?",
                    "Maravilha! 😊 O que você precisa?"
                ])
            elif contexto_atual == "social":
                return random.choice([
                    "Que bom! 😊 E aí, como posso ajudar?",
                    "Fico feliz! Tem algo do WinThor que precisa?",
                    "Maravilha então! No que posso ajudar?"
                ])
            else:
                return random.choice([
                    "Que bom! 😊 Como posso ajudar?",
                    "Fico feliz! No que posso ajudar?",
                    "Maravilha! Em que posso ser útil?"
                ])
        
        # Outras expressões sociais
        return random.choice([
            "Vou bem! 😊 Como posso ajudar?",
            "Estou bem! No que posso ajudar?",
            "Tudo certo! O que você precisa?"
        ])
    
    # AGRADECIMENTO
    if any(a in p_limpo for a in agradecimentos) and len(palavras) <= 4:
        historico_conversa[-1]["contexto"] = "agradecimento"
        if 'valeu' in p_limpo:
            return random.choice(["Valeu você! 😊 Precisando, tamo aí!", "Tamo junto! 🤝"])
        else:
            return random.choice([
                "De nada! 😊 Precisando, é só chamar!",
                "Por nada! Estou aqui para ajudar!",
                "Imagina! 😊 Conte comigo!"
            ])
    
    # DESPEDIDA
    if any(d in palavras for d in despedidas):
        historico_conversa[-1]["contexto"] = "despedida"
        return random.choice([
            "Vlw! 😊 Precisando, tamo aí!",
            "Flw! 😊 Qualquer coisa, só chamar!",
            "Tchau! 😊 Até a próxima!",
            "Até mais! 👋 Volte sempre!"
        ])
    
    # RISOS
    tem_risos = any(r in pergunta_usuario.lower() for r in ['kkk', 'kkkk', 'haha', 'hehe', 'hihi', 'rsrs', 'rs'])
    if tem_risos and len(palavras) <= 3:
        historico_conversa[-1]["contexto"] = "social"
        return random.choice(["Kkkk! 😄 Pois é!", "Haha! 😂 No que posso ajudar?", "Rsrs! 😆 Tem alguma dúvida?"])
    
    # ==================================================
    # 2. ASSUNTO TÉCNICO (inclui imagem de erro)
    # ==================================================
    if tem_assunto_tecnico or '[ERRO DETECTADO EM IMAGEM]' in pergunta_usuario:
        historico_conversa[-1]["contexto"] = "tecnico"
        return processar_pergunta_tecnica(pergunta_usuario)
    
    # ==================================================
    # 3. CONTEXTO DE ROTINA ANTERIOR
    # ==================================================
    rotina_contexto = None
    for item in reversed(historico_conversa):
        perg = item.get("pergunta", "")
        rot = extrair_numero_rotina(perg)
        if rot:
            rotina_contexto = rot
            break
    
    if rotina_contexto:
        historico_conversa[-1]["contexto"] = "tecnico"
        return processar_pergunta_tecnica(pergunta_usuario)
    
    # ==================================================
    # 4. FRASE CURTA (não identificada)
    # ==================================================
    if len(palavras) <= 3:
        historico_conversa[-1]["contexto"] = "duvida"
        return random.choice([
            "🤔 Não entendi bem. Pode me explicar melhor?",
            "Fiquei na dúvida. Tem alguma pergunta sobre o WinThor?",
            "Desculpe, não compreendi. Pode me dar mais detalhes?",
            "Quer saber sobre alguma rotina? Me fala o número!"
        ])
    
    # ==================================================
    # 5. NADA ENCONTRADO
    # ==================================================
    historico_conversa[-1]["contexto"] = "generico"
    return random.choice([
        "🤔 Não encontrei nada específico. Tente:\n• Número da rotina (ex: '220')\n• Módulo (Compra, Venda...)\n• Imagem da tela\n\nO que acha? 😊",
        "Hmm, não tenho essa informação ainda. 😅 Me fala qual rotina ou módulo para eu ajudar!",
        "Não consegui identificar. 😕 Qual rotina do WinThor você está usando?"
    ])


# ==================================================
# PROCESSAR PERGUNTA TÉCNICA
# ==================================================
def processar_pergunta_tecnica(pergunta):
    
    cache = buscar_resposta_memorizada(pergunta)
    if cache:
        return cache + "\n\n_(Baseado em conversas anteriores)_"
    
    rotina_contexto = None
    for item in reversed(historico_conversa):
        perg = item.get("pergunta", "")
        rot = extrair_numero_rotina(perg)
        if rot:
            rotina_contexto = rot
            break
    
    codigo_atual = extrair_numero_rotina(pergunta)
    
    if codigo_atual:
        tem_pergunta_especifica = any(p in pergunta.lower() for p in 
            ['como fazer', 'como usar', 'como emitir', 'como gerar', 'como lançar',
             'onde', 'qual', 'quando', 'porque', 'por que', 'oque', 'o que', 
             'explica', 'ensina', 'passo', 'etapa', 'erro', 'problema', 'resolver',
             'saber', 'entender', 'verificar', 'consultar', 'aprovar', 'rejei', 'status'])
        
        if not tem_pergunta_especifica and codigo_atual in rotinas_dict:
            info = rotinas_dict[codigo_atual]
            resp = f"**Rotina {codigo_atual} - {info['nome']}**\n"
            resp += f"Módulo: {info['modulo']}\n\n"
            resp += f"{info['explicacao']}\n\n"
            
            conexoes = buscar_conexoes_rotina(codigo_atual)
            if conexoes:
                antes = [c for c in conexoes if c["tipo"] == "antes"]
                depois = [c for c in conexoes if c["tipo"] == "depois"]
                
                if antes:
                    resp += "⬅️ **Rotinas que você precisa antes:**\n"
                    for c in antes[:3]:
                        resp += f"• Rotina {c['rotina']} - {c['nome']}: {c['relacao']}\n"
                    resp += "\n"
                
                if depois:
                    resp += "➡️ **Rotinas que vêm depois:**\n"
                    for c in depois[:3]:
                        resp += f"• Rotina {c['rotina']} - {c['nome']}: {c['relacao']}\n"
                    resp += "\n"
            
            fluxo = buscar_fluxo_completo(codigo_atual)
            if fluxo:
                resp += f"🔄 **Fluxo completo: {fluxo['processo']}**\n"
                for i, etapa in enumerate(fluxo['etapas']):
                    marcador = "👉" if etapa['rotina'] == codigo_atual else "  "
                    resp += f"{marcador} {i+1}. Rotina {etapa['rotina']} - {etapa['acao']}\n"
                resp += "\n"
            
            resp += "**O que você gostaria de saber?**\n\n"
            resp += "📋 Passo a passo | 🔗 Conexões | ❌ Erros comuns\n"
            resp += "É só me falar! 😊"
            salvar_aprendizado(pergunta, resp, f"rotina_{codigo_atual}")
            return resp
        
        if codigo_atual in tutoriais_dict:
            return formatar_tutorial(tutoriais_dict[codigo_atual], pergunta)
        if codigo_atual in rotinas_dict:
            return formatar_resposta_contexto(codigo_atual, rotinas_dict[codigo_atual], pergunta)
        else:
            proximos = rotinas_proximas(codigo_atual)
            sugestao = f"Rotinas próximas: {', '.join(map(str, proximos[:5]))}" if proximos else ""
            return f"🤔 Rotina {codigo_atual} não encontrada.\n\n{sugestao}"
    
    if rotina_contexto:
        if rotina_contexto in tutoriais_dict:
            return formatar_tutorial(tutoriais_dict[rotina_contexto], pergunta)
        if rotina_contexto in rotinas_dict:
            return formatar_resposta_contexto(rotina_contexto, rotinas_dict[rotina_contexto], pergunta)
    
    erro = detectar_erro(pergunta)
    if erro:
        guardar_contexto_erro(erro)
        salvar_aprendizado(pergunta, erro, "erro")
        return erro + "\n\n💡 Quer saber como resolver? Peça 'me ensina o passo a passo'! 😊"

    # Se menciona "base nova", "ambiente novo" ou similar, busca priorizada
    palavras_base_nova = ['base nova', 'ambiente novo', 'base limpa', 'migrar', 'migração', 
                          'do zero', 'atualizar base', 'atualizar banco', 'atualizar winthor',
                          'nova instalacao', 'instalação nova', 'base do zero', 'atualizar o banco',
                          'criar base', 'montar base']
    
    termos = set(re.findall(r'\b\w{3,}\b', pergunta.lower()))
    # Se menciona "base nova", "ambiente novo" ou similar, busca priorizada
    palavras_base_nova = ['base nova', 'ambiente novo', 'base limpa', 'migrar', 'migração', 
                          'do zero', 'atualizar base', 'atualizar banco', 'atualizar winthor',
                          'nova instalacao', 'instalação nova', 'base do zero']
    
    if any(p in pergunta.lower() for p in palavras_base_nova):
        # Prioriza rotinas de atualização de base
        resp = "🔍 **Para atualizar/criar uma base nova do WinThor, você precisa destas rotinas:**\n\n"
        resp += "📝 **500 - Atualizar Procedure** (PROCESSAMENTO)\n"
        resp += "   Atualiza procedures armazenadas no banco de dados.\n\n"
        resp += "📝 **560 - Atualizar Banco de Dados** (PROCESSAMENTO)\n"
        resp += "   Aplica scripts de atualização na estrutura do banco.\n\n"
        resp += "📝 **801 - Atualização de Serviços Web** (PROCESSAMENTO)\n"
        resp += "   Atualiza serviços web (WTA).\n\n"
        resp += "📝 **814 - Atualização de objeto de banco** (PROCESSAMENTO)\n"
        resp += "   Atualiza objetos de banco (views, functions, triggers).\n\n"
        resp += "🔄 **Ordem correta:** 560 → 500 → 1400 → 814 → 801\n\n"
        resp += "Quer o passo a passo detalhado de alguma dessas? Me diga o número! 😊"
        salvar_aprendizado(pergunta, resp, "base_nova")
        return resp    
    # Palavras que indicam ação específica (peso extra)
    palavras_acao = {
        'atualizar': ['atualizar', 'atualizo', 'atualiza', 'atualização', 'atualizacao'],
        'cadastrar': ['cadastrar', 'cadastro', 'cadastrando'],
        'emitir': ['emitir', 'emito', 'emissão', 'emissao'],
        'digitar': ['digitar', 'digito', 'digitação', 'digitacao'],
        'lançar': ['lançar', 'lanco', 'lançamento', 'lancamento'],
        'gerar': ['gerar', 'gero', 'geração', 'geracao'],
        'procedure': ['procedure', 'procedures', 'procedimento', 'procedimentos'],
        'banco': ['banco', 'database', 'bd', 'tabela', 'tabelas'],
        'serviço': ['serviço', 'servico', 'serviços', 'servicos', 'wta', 'web'],
        'fiscal': ['fiscal', 'nf', 'nfe', 'nf-e', 'sefaz', 'nota'],
        'compra': ['compra', 'compras', 'pedido', 'fornecedor'],
        'venda': ['venda', 'vendas', 'cliente', 'pdv'],
        'estoque': ['estoque', 'produto', 'produtos', 'armazen']
    }
    
    # Calcula peso extra baseado em palavras de ação
    peso_extra = {}
    for categoria, palavras in palavras_acao.items():
        if any(p in pergunta.lower() for p in palavras):
            for cod, info in rotinas_dict.items():
                texto_busca = f"{info['nome']} {info['explicacao']}".lower()
                # Se a rotina contém palavras da mesma categoria, ganha peso
                for p in palavras:
                    if p in texto_busca:
                        peso_extra[cod] = peso_extra.get(cod, 0) + 10
    
    for cod, tutorial in tutoriais_dict.items():
        texto_busca = f"{tutorial['titulo']} {tutorial['descricao_curta']} {' '.join(tutorial.get('termos_busca', []))}".lower()
        if sum(1 for t in termos if t in texto_busca) >= 2:
            return formatar_tutorial(tutorial, pergunta)
    
    candidatos = []
    for cod, info in rotinas_dict.items():
        texto_busca = f"{info['nome']} {info['explicacao']}".lower()
        pontuacao = sum(1 for t in termos if t in texto_busca)
        # Adiciona peso extra
        pontuacao += peso_extra.get(cod, 0)
        if pontuacao > 0:
            candidatos.append((cod, info, pontuacao))
    
    candidatos.sort(key=lambda x: x[2], reverse=True)

    if candidatos:
        resp = "🔍 **Rotinas relacionadas:**\n\n"
        for cod, info, _ in candidatos[:5]:
            tem_tutorial = "📚" if cod in tutoriais_dict else "📝"
            resp += f"{tem_tutorial} **{cod} - {info['nome']}**\n"
            resp += f"   📂 {info['modulo']}\n"
            resp += f"   {info['explicacao'][:150]}...\n\n"
        resp += "Qual dessas? Me diga o número! 😊"
        salvar_aprendizado(pergunta, resp, "consulta")
        return resp
    
    return "Não encontrei uma rotina específica. Me dê mais detalhes ou o número da rotina?"


def formatar_resposta_contexto(codigo, info, pergunta):
    contexto_extra = ""
    if codigo in tutoriais_dict:
        tut = tutoriais_dict[codigo]
        contexto_extra = f"\nPassos: {'; '.join(tut['passo_a_passo'])}\nDicas: {'; '.join(tut.get('dicas', []))}"
    
    try:
        prompt = f"""Você é um colega de trabalho que conhece bem o WinThor. Responda de forma natural e amigável.

O usuário está com dúvida sobre a Rotina {codigo} - {info['nome']} (Módulo: {info['modulo']}).

📝 O que a rotina faz: {info['explicacao']}
🔗 Dependências: {', '.join(map(str, info['dependencias'])) if info['dependencias'] else 'Nenhuma'}
👉 Próxima rotina: {info['proxima']}{contexto_extra}

🗣️ O usuário perguntou: "{pergunta}"

📋 INSTRUÇÕES:
- Responda como um colega de trabalho explicando algo (natural, direto)
- NÃO use cabeçalhos como "📂 Título" ou "📝 Descrição"
- Seja direto e objetivo (3-6 linhas)
- Se for sobre erro/rejeição, explique como resolver
- Use emojis com moderação
- Termine oferecendo mais ajuda"""
        
        resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.7, "num_predict": 250})
        resp = resposta_ia['response']
        resp += f"\n\n💡 Quer mais detalhes? Pode me perguntar! 😊"
    except:
        resp = f"{info['explicacao']}\n\n"
        resp += f"💡 Me pergunte 'me ensina o passo a passo' para ver todas as etapas! 😊"
    
    salvar_aprendizado(pergunta, resp, f"contexto_{codigo}")
    return resp


def formatar_tutorial(tutorial, pergunta):
    global ultimo_erro_detectado
    
    # Se tem erro no contexto, SEMPRE prioriza responder sobre o erro
    if ultimo_erro_detectado:
        palavras_tutorial = ['passo a passo', 'como usar', 'como fazer', 'ensina', 'me ensina', 
                             'tutorial', 'como é', 'explica tudo', 'detalhado', 'completo',
                             'passo apasso', 'me ensine', 'mostre', 'me mostre']
        
        if any(p in pergunta.lower() for p in palavras_tutorial):
            # Usuário pediu passo a passo - responde sobre o ERRO
            texto_erro = ultimo_erro_detectado[:800]
            ultimo_erro_detectado = None  # Limpa
            
            try:
                prompt = f"""Especialista WinThor. O usuário enviou uma imagem com este erro:

{texto_erro}

Ele pediu: "{pergunta}"

INSTRUÇÕES:
- Explique COMO RESOLVER ESTE ERRO ESPECÍFICO em passos claros
- Mencione as rotinas necessárias (ex: 801, 560, 500)
- Seja direto e didático (4-8 linhas)
- NÃO fale sobre emitir NF-e se o erro não for sobre isso
- Foque APENAS no erro que ele mostrou"""
                
                resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 300})
                resp = resposta_ia['response']
                resp += f"\n\n💡 Isso deve resolver! Depois me conta se funcionou. 😊"
                salvar_aprendizado(pergunta, resp, "erro_contexto")
                return resp
            except:
                resp = "Para resolver esse erro, siga estes passos:\n\n"
                resp += "1. Acesse a rotina 801 - Atualização de Serviços\n"
                resp += "2. Verifique os serviços pendentes de atualização\n"
                resp += "3. Atualize o serviço mencionado na mensagem de erro\n"
                resp += "4. Tente acessar a rotina novamente\n\n"
                resp += "💡 Depois me conta se funcionou! 😊"
                salvar_aprendizado(pergunta, resp, "erro_contexto")
                return resp
        
        # Se não pediu passo a passo, mas tem erro, responde sobre o erro
        texto_erro = ultimo_erro_detectado[:500]
        ultimo_erro_detectado = None
        try:
            prompt = f"""Usuário enviou este erro: {texto_erro}
E perguntou: "{pergunta}"
Responda de forma natural e direta (3-5 linhas) explicando como resolver."""
            resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 200})
            return resposta_ia['response'] + f"\n\n💡 Quer o passo a passo? Peça 'me ensina o passo a passo'! 😊"
        except:
            return "Parece um erro de serviço/atualização. Acesse a rotina 801 e verifique as atualizações pendentes.\n\n💡 Quer o passo a passo? Peça 'me ensina'!"
    
    # Comportamento normal (sem erro no contexto)
    palavras_tutorial = ['passo a passo', 'como usar', 'como fazer', 'ensina', 'me ensina', 
                         'tutorial', 'como é', 'explica tudo', 'detalhado', 'completo',
                         'passo apasso', 'me ensine']
    
    if not any(p in pergunta.lower() for p in palavras_tutorial):
        try:
            prompt = f"""Colega de trabalho que conhece WinThor. Dados:
{tutorial['titulo']}
Passos: {'; '.join(tutorial['passo_a_passo'])}
Dicas: {'; '.join(tutorial.get('dicas', []))}

Usuário perguntou: "{pergunta}"
Responda de forma natural e direta (3-5 linhas). Foque APENAS na dúvida."""
            resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 200})
            resp = resposta_ia['response']
            resp += f"\n\n💡 Quer o passo a passo completo? Peça 'me ensina o passo a passo'! 😊"
        except:
            resp = f"{tutorial['descricao_curta']}\n\n"
            resp += f"💡 Me pergunte 'me ensina o passo a passo'! 😊"
        salvar_aprendizado(pergunta, resp, f"tutorial_{tutorial['rotina']}")
        return resp
    
    # Passo a passo normal
    resp = "**🚶 Passo a passo:**\n"
    for i, passo in enumerate(tutorial['passo_a_passo']):
        resp += f"{i+1}. {passo}\n"
    if tutorial.get('dicas'):
        resp += f"\n**💡 Dicas importantes:**\n"
        for dica in tutorial['dicas']:
            resp += f"• {dica}\n"
    resp += f"\nConseguiu entender? Dúvida em algum passo? 😊"
    salvar_aprendizado(pergunta, resp, f"tutorial_{tutorial['rotina']}")
    return resp


# ==================================================
# SERVIDOR FLASK
# ==================================================
app = Flask(__name__)
app.config['MAX_CONTENT_LENGTH'] = 16 * 1024 * 1024

HTML_TEMPLATE = """
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>WinThor IA · Assistente Técnico Inteligente</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif; }
    body { background: #081120; }
