# ==================================================
# FUNÇÕES AUXILIARES
# ==================================================
def extrair_numero_rotina(texto):
    padroes = [
        r'\b(?:rotina|código|codigo|numero|número|me dê a|mostre a|qual a|a rotina|fala da|explique a|o que é a|sobre a|consulte a|pesquise a)\s*(\d{3,4})\b',
        r'\b(\d{3,4})\b'
    ]
    for padrao in padroes:
        match = re.search(padrao, texto, re.IGNORECASE)
        if match:
            return int(match.group(1))
    return None

def rotinas_proximas(codigo, limite=5):
    codigos = sorted(rotinas_dict.keys())
    if codigo in codigos:
        return []
    pos = 0
    for i, c in enumerate(codigos):
        if c > codigo:
            pos = i
            break
    return codigos[max(0, pos-limite//2):pos+limite//2]

def extrair_texto_imagem_bytes(imagem_bytes):
    try:
        imagem = Image.open(BytesIO(imagem_bytes))
        imagem.thumbnail((800, 800))
        imagem_np = np.array(imagem)
        resultado = ocr_reader.readtext(imagem_np, detail=0, paragraph=True)
        texto = " ".join(resultado)
        return texto.strip()
    except:
        return ""

def detectar_erro(texto):
    if any(p in texto.lower() for p in ['duvida', 'dúvida', 'como', 'explica', 'ensina', 'ajuda', 'saber']):
        return None
    
    texto_lower = texto.lower()
    for erro in erros_lista:
        palavras = erro.get("palavras_chave", [])
        for p in palavras:
            if p.startswith("ORA-") and p.lower() in texto_lower:
                return guardar_contexto_erro(formatar_resposta_erro(erro, texto))
    
    melhor_erro = None
    melhor_pontuacao = 0
    for erro in erros_lista:
        palavras = erro.get("palavras_chave", [])
        pontuacao = sum(len(p) for p in palavras if p.lower() in texto_lower)
        codigos = erro.get("codigos_rotina_relacionados", [])
        pontuacao += sum(50 for c in codigos if str(c) in texto_lower)
        if pontuacao > melhor_pontuacao:
            melhor_pontuacao = pontuacao
            melhor_erro = erro
    
    if melhor_pontuacao >= 6:
        return guardar_contexto_erro(formatar_resposta_erro(melhor_erro, texto))
    return None

def formatar_resposta_erro(erro, pergunta_original):
    pergunta_lower = pergunta_original.lower()
    
    if any(p in pergunta_lower for p in ['socorro', 'urgente', 'parou']):
        abertura = random.choice(["😰 Calma, vamos resolver! Já vi esse erro...", "Respira fundo! 😊 Tem solução:"])
    elif '[ERRO DETECTADO' in pergunta_original:
        abertura = random.choice(["📸 Pela imagem, identifiquei o erro!", "Analisei a imagem e já sei o que é! 😊"])
    else:
        abertura = random.choice(["🔍 Encontrei algo:", "Hummm, esse erro é conhecido!", "Já vi isso acontecer!"])
    
    resposta = f"{abertura}\n\n📌 **{erro.get('titulo')}**\n\n"
    resposta += f"🧠 **Por que acontece:**\n{erro.get('causa')}\n\n"
    resposta += f"✅ **Como resolver:**\n{erro.get('solucao')}\n\n"
    
    codigos = erro.get("codigos_rotina_relacionados", [])
    if codigos:
        resposta += f"🔗 **Rotinas úteis:** {', '.join(map(str, codigos))}\n\n"
    if erro.get('proximo_passo_sugerido'):
        resposta += f"👣 **Sugiro:** {erro['proximo_passo_sugerido']}\n\n"
    
    resposta += random.choice(["Conseguiu entender? 😊", "Ficou alguma dúvida?", "Depois me conta se deu certo!"])
    return resposta

def analisar_imagem_rotina(imagem_bytes):
    global ultimo_erro_detectado
    
    texto_extraido = extrair_texto_imagem_bytes(imagem_bytes)
    if not texto_extraido or len(texto_extraido) < 5:
        return "[Imagem enviada - qualidade baixa]"
    
    palavras_erro = ['erro', 'atenção', 'falha', 'ORA-', 'mensagem', 'banco de dados', 
                     'identificador inválido', 'não foi possível', '404', 'serviço',
                     'servico', 'validação', 'validacao', 'versão', 'versao', 'atualiza']
    
    eh_erro = any(p in texto_extraido.lower() for p in palavras_erro)
    numero_rotina = extrair_numero_rotina(texto_extraido)
    
    if eh_erro:
        # GUARDA o texto do erro para contexto futuro
        ultimo_erro_detectado = texto_extraido[:800]
        
        resultado = f"[ERRO DETECTADO EM IMAGEM]\n\n{texto_extraido[:800]}"
        if numero_rotina:
            resultado += f"\n\n📌 Rotina mencionada: {numero_rotina}"
            ultimo_erro_detectado += f"\n\n📌 Rotina mencionada: {numero_rotina}"
        return resultado
    
    if numero_rotina and numero_rotina in rotinas_dict:
        info = rotinas_dict[numero_rotina]
        return f"[Imagem da Rotina {numero_rotina} - {info['nome']}]\n\nConteúdo:\n{texto_extraido[:500]}"
    
    return f"[Imagem de tela WinThor]\n\nConteúdo:\n{texto_extraido[:500]}"

def buscar_conexoes_rotina(codigo):
    conexoes = []
    for conn in fluxos_rotinas.get("conexoes", []):
        if conn["origem"] == codigo:
            conexoes.append({
                "tipo": "depois",
                "rotina": conn["destino"],
                "nome": rotinas_dict.get(conn["destino"], {}).get("nome", f"Rotina {conn['destino']}"),
                "relacao": conn["relacao"]
            })
        if conn["destino"] == codigo:
            conexoes.append({
                "tipo": "antes",
                "rotina": conn["origem"],
                "nome": rotinas_dict.get(conn["origem"], {}).get("nome", f"Rotina {conn['origem']}"),
                "relacao": conn["relacao"]
            })
    return conexoes

def buscar_fluxo_completo(codigo):
    for fluxo in fluxos_rotinas.get("fluxos", []):
        for etapa in fluxo["etapas"]:
            if etapa["rotina"] == codigo:
                return fluxo
    return None

