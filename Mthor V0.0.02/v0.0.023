      background: radial-gradient(circle at top left, rgba(59,130,246,0.20), transparent 25%),
                  radial-gradient(circle at right, rgba(34,211,238,0.10), transparent 20%),
                  linear-gradient(135deg, #06101f 0%, #0a1630 35%, #0b2147 70%, #10376b 100%); color: white; }
    .sidebar { border-right: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.04); backdrop-filter: blur(10px); padding: 24px 16px; }
    .logoBox { display: flex; align-items: center; gap: 12px; margin-bottom: 30px; padding: 14px; border-radius: 18px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); }
    .logoIcon { width: 44px; height: 44px; border-radius: 14px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(56,189,248,0.35), rgba(37,99,235,0.35)); font-weight: bold; font-size: 20px; }
    .miniText { font-size: 12px; color: #b8c4db; }
    .logoBox h2 { font-size: 18px; }
    .menu { display: flex; flex-direction: column; gap: 10px; }
    .menuItem { border: none; background: transparent; color: #d5dff3; text-align: left; padding: 14px 16px; border-radius: 14px; cursor: pointer; transition: 0.3s; font-weight: 500; }
    .menuItem:hover { background: rgba(255,255,255,0.06); color: white; }
    .menuItem.active { background: linear-gradient(90deg, rgba(56,189,248,0.18), rgba(37,99,235,0.14)); border: 1px solid rgba(125,211,252,0.18); color: white; }
    .sidebarCard { margin-top: 28px; padding: 18px; border-radius: 22px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); }
    .sidebarCard h3 { margin: 8px 0 10px; }
    .sidebarCard p { color: #c7d2e6; font-size: 14px; line-height: 1.6; }
    .main { padding: 28px; overflow-y: auto; }
    .hero { display: grid; grid-template-columns: 1.4fr 0.8fr; gap: 24px; padding: 28px; border-radius: 28px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(10px); box-shadow: 0 10px 35px rgba(0,0,0,0.25); }
    .tag { display: inline-block; margin-bottom: 16px; padding: 8px 14px; border-radius: 999px; font-size: 12px; background: rgba(34,211,238,0.10); border: 1px solid rgba(125,211,252,0.18); color: #d9f6ff; }
    .heroText h1 { font-size: 42px; line-height: 1.15; margin-bottom: 16px; }
    .heroText p { color: #d3ddf0; font-size: 16px; line-height: 1.7; max-width: 760px; }
    .searchArea { margin-top: 24px; display: flex; gap: 12px; }
    .searchArea input, .chatInput input { flex: 1; height: 48px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.08); background: rgba(2,6,23,0.45); color: white; padding: 0 16px; outline: none; font-size: 14px; }
    .primaryBtn { border: none; border-radius: 14px; padding: 0 20px; min-height: 48px; background: linear-gradient(90deg, #38bdf8, #2563eb); color: white; font-weight: bold; cursor: pointer; transition: 0.3s; }
    .primaryBtn:hover { transform: translateY(-1px); opacity: 0.95; }
    .secondaryBtn { border: 1px solid rgba(255,255,255,0.10); background: rgba(2,6,23,0.35); color: white; border-radius: 14px; padding: 12px 16px; cursor: pointer; transition: 0.3s; font-weight: 500; }
    .secondaryBtn:hover { background: rgba(255,255,255,0.08); }
    .statusPanel { display: flex; flex-direction: column; gap: 14px; }
    .statusCard { padding: 18px; border-radius: 20px; background: rgba(2,6,23,0.38); border: 1px solid rgba(255,255,255,0.08); }
    .statusCard span { display: block; color: #aebad1; font-size: 13px; margin-bottom: 6px; }
    .statusCard strong { font-size: 20px; }
    .modules { margin-top: 24px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    .moduleCard { padding: 22px; border-radius: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(10px); transition: 0.3s; }
    .moduleCard:hover { transform: translateY(-4px); background: rgba(255,255,255,0.07); }
    .moduleCard h3 { margin-bottom: 10px; font-size: 20px; }
    .moduleCard p { color: #ccd7eb; font-size: 14px; line-height: 1.6; min-height: 95px; }
    .contentGrid { margin-top: 24px; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 18px; }
    .chatBox, .infoCard { padding: 24px; border-radius: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(10px); }
    .chatBox h2, .infoCard h3 { margin-bottom: 10px; }
    .sectionText { color: #cbd7eb; margin-bottom: 20px; line-height: 1.6; }
    .chatMessages { max-height: 380px; overflow-y: auto; margin-bottom: 16px; display: flex; flex-direction: column; gap: 12px; padding-right: 4px; }
    .message { padding: 16px; border-radius: 18px; }
    .message span { font-size: 13px; display: block; margin-bottom: 8px; color: #dce9ff; font-weight: 600; }
    .message p { color: #ecf3ff; line-height: 1.6; font-size: 14px; white-space: pre-wrap; }
    .message.ai { background: rgba(56,189,248,0.10); border: 1px solid rgba(125,211,252,0.12); }
    .message.user { background: rgba(2,6,23,0.35); border: 1px solid rgba(255,255,255,0.08); }
    .chatInput { display: flex; gap: 12px; margin-top: 8px; align-items: center; flex-wrap: wrap; }
    .file-label-chat { background: rgba(56,189,248,0.2); padding: 12px 16px; border-radius: 14px; cursor: pointer; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(125,211,252,0.3); }
    .file-label-chat:hover { background: rgba(56,189,248,0.3); }
    .sideInfo { display: flex; flex-direction: column; gap: 18px; }
    .infoCard ul { padding-left: 18px; color: #d6e0f3; line-height: 1.9; font-size: 14px; }
    .highlight { background: linear-gradient(180deg, rgba(56,189,248,0.08), rgba(37,99,235,0.08)); }
    .preview-img-chat { max-width: 60px; max-height: 60px; border-radius: 8px; margin-top: 8px; border: 1px solid rgba(255,255,255,0.2); }
    .remove-img-chat { background: #e53e3e; padding: 4px 8px; border-radius: 20px; font-size: 11px; cursor: pointer; display: inline-block; margin-left: 10px; }
    @media (max-width: 1100px) { .app { grid-template-columns: 1fr; } .sidebar { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); } .hero, .contentGrid, .modules { grid-template-columns: 1fr; } .heroText h1 { font-size: 32px; } }
    @media (max-width: 700px) { .main { padding: 18px; } .hero, .chatInput, .searchArea { display: flex; flex-direction: column; } .primaryBtn, .secondaryBtn { width: 100%; justify-content: center; } }
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <div class="logoBox"><div class="logoIcon">W</div><div><p class="miniText">Assistente</p><h2>WinThor IA</h2></div></div>
    <nav class="menu">
      <button class="menuItem active" data-menu="visao">Visão geral</button>
      <button class="menuItem" data-menu="rotinas">Rotinas</button>
      <button class="menuItem" data-menu="dependencias">Dependências</button>
      <button class="menuItem" data-menu="banco">Banco</button>
      <button class="menuItem" data-menu="fiscal">Fiscal</button>
      <button class="menuItem" data-menu="historico">Histórico</button>
    </nav>
    <div class="sidebarCard">
      <p class="miniText">Projeto</p>
      <h3>Painel técnico moderno</h3>
      <p>Interface pensada para suporte, consultas rápidas e respostas sobre erros do WinThor.</p>
      <button class="primaryBtn" id="openAtendimentoBtn">Abrir atendimento</button>
    </div>
  </aside>
  <main class="main">
    <section class="hero">
      <div class="heroText">
        <span class="tag">Design moderno • Azul com gradiente</span>
        <h1>Central inteligente de apoio para o projeto WinThor</h1>
        <p>Layout visual mais corporativo, limpo e moderno, com foco em suporte técnico, rotinas, banco de dados, dependências e fiscal.</p>
        <div class="searchArea"><input type="text" id="globalSearchInput" placeholder="Pesquisar rotina, erro, package, dependência..."><button class="primaryBtn" id="globalSearchBtn">Consultar</button></div>
      </div>
      <div class="statusPanel">
        <div class="statusCard"><span>Ambiente</span><strong>Cloud ativo</strong></div>
        <div class="statusCard"><span>Monitoramento</span><strong>Estável</strong></div>
        <div class="statusCard"><span>Última validação</span><strong>Concluída</strong></div>
      </div>
    </section>
    <section class="modules">
      <div class="moduleCard" data-module="Rotinas"><h3>Rotinas</h3><p>Consultas sobre 300, 500, 560, 801, 814, 2075 e outras rotinas do WinThor.</p><button class="secondaryBtn moduleBtn">Abrir módulo</button></div>
      <div class="moduleCard" data-module="Atualizações"><h3>Atualizações</h3><p>Dependências, validação de versões, WTA, packages e sincronizações do ambiente.</p><button class="secondaryBtn moduleBtn">Abrir módulo</button></div>
      <div class="moduleCard" data-module="Banco de Dados"><h3>Banco de Dados</h3><p>Apoio para objetos inválidos, PL/SQL, tabelas e validações técnicas.</p><button class="secondaryBtn moduleBtn">Abrir módulo</button></div>
      <div class="moduleCard" data-module="Fiscal"><h3>Fiscal</h3><p>Suporte em DocFiscal, NF-e, contingência, SEFAZ e erros operacionais.</p><button class="secondaryBtn moduleBtn">Abrir módulo</button></div>
    </section>
    <section class="contentGrid">
      <div class="chatBox">
        <h2>Chat técnico principal</h2>
        <p class="sectionText">Área para o usuário descrever erro, rotina ou dependência e receber resposta contextualizada. <strong>Dica: cole uma imagem (Ctrl+V) na caixa de texto!</strong></p>
        <div class="chatMessages" id="chatMessagesContainer"><div class="message ai"><span>Assistente IA</span><p>Olá! Posso ajudar com rotinas do WinThor, erros de atualização, dependências no WTA, objetos inválidos no banco e dúvidas fiscais.</p></div></div>
        <div class="chatInput">
          <input type="text" id="chatMessageInput" placeholder="Descreva o erro ou cole uma imagem (Ctrl+V)...">
          <input type="file" id="imageUploadChat" accept="image/*" style="display: none;">
          <label for="imageUploadChat" class="file-label-chat">📷 Imagem</label>
          <button class="primaryBtn" id="sendChatBtn">Enviar</button>
        </div>
        <div id="previewChat"></div>
      </div>
      <div class="sideInfo">
        <div class="infoCard"><h3>Alertas e pontos críticos</h3><ul><li>Objetos inválidos no schema</li><li>Dependências não sincronizadas no WTA</li><li>Erros fiscais com impacto operacional</li><li>Falhas em atualização de package</li></ul></div>
        <div class="infoCard highlight"><h3>Estilo aplicado</h3><ul><li>Fundo azul escuro com gradiente sofisticado</li><li>Visual moderno e corporativo</li><li>Cards translúcidos</li><li>Verde reduzido ao mínimo</li></ul></div>
      </div>
    </section>
  </main>
</div>
<script>
  (function() {
    const chatContainer = document.getElementById('chatMessagesContainer');
    const globalSearchInput = document.getElementById('globalSearchInput');
    const globalSearchBtn = document.getElementById('globalSearchBtn');
    const chatInputField = document.getElementById('chatMessageInput');
    const sendChatBtn = document.getElementById('sendChatBtn');
    const openAtendimento = document.getElementById('openAtendimentoBtn');
    const menuItems = document.querySelectorAll('.menuItem');
    const moduleBtns = document.querySelectorAll('.moduleBtn');
    const imageUpload = document.getElementById('imageUploadChat');
    const previewDiv = document.getElementById('previewChat');
    let currentImageBase64 = null;

    function addMessage(sender, text, senderName = null) {
      const messageDiv = document.createElement('div');
      messageDiv.classList.add('message', sender === 'user' ? 'user' : 'ai');
      const span = document.createElement('span');
      span.innerText = sender === 'user' ? (senderName || 'Usuário') : (senderName || 'Assistente IA');
      const p = document.createElement('p');
      p.innerText = text;
      messageDiv.appendChild(span);
      messageDiv.appendChild(p);
      chatContainer.appendChild(messageDiv);
      messageDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    async function sendToBackend(mensagem, imagemBase64) {
      if (!mensagem && !imagemBase64) return;
      addMessage('user', mensagem || '[Imagem enviada]');
      const typingDiv = document.createElement('div');
      typingDiv.classList.add('message', 'ai');
      typingDiv.innerHTML = '<span>Assistente IA</span><p>🤔 Processando...</p>';
      chatContainer.appendChild(typingDiv);
      typingDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      try {
        const response = await fetch('/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ mensagem: mensagem, imagem: imagemBase64 }) });
        const data = await response.json();
        typingDiv.remove();
        if (data.erro) addMessage('ai', `❌ Erro: ${data.erro}`);
        else addMessage('ai', data.resposta);
      } catch (err) {
        typingDiv.remove();
        addMessage('ai', `❌ Erro de comunicação: ${err.message || err}`);
      }
    }

    function handleSend() {
      const msg = chatInputField.value.trim();
      if (!msg && !currentImageBase64) return;
      const imagem = currentImageBase64;
      chatInputField.value = '';
      clearImagePreview();
      sendToBackend(msg, imagem);
    }

    function clearImagePreview() {
      currentImageBase64 = null;
      previewDiv.innerHTML = '';
      imageUpload.value = '';
    }

    imageUpload.addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function(event) {
          currentImageBase64 = event.target.result;
          previewDiv.innerHTML = `<img src="${currentImageBase64}" class="preview-img-chat" alt="Preview"><span class="remove-img-chat" onclick="clearImagePreview()">❌ Remover</span>`;
        };
        reader.readAsDataURL(file);
      }
    });
    chatInputField.addEventListener('paste', async function(e) {
      const items = e.clipboardData.items;
      for (let i = 0; i < items.length; i++) {
        if (items[i].type.indexOf('image') !== -1) {
          e.preventDefault();
          const blob = items[i].getAsFile();
          const reader = new FileReader();
          reader.onload = function(event) {
            currentImageBase64 = event.target.result;
            previewDiv.innerHTML = `<img src="${currentImageBase64}" class="preview-img-chat" alt="Preview"><span class="remove-img-chat" onclick="clearImagePreview()">❌ Remover</span>`;
          };
          reader.readAsDataURL(blob);
          break;
        }
      }
    });
    window.clearImagePreview = clearImagePreview;
    globalSearchBtn.addEventListener('click', () => { const query = globalSearchInput.value.trim(); if (query) { globalSearchInput.value = ''; sendToBackend(query, null); } });
    globalSearchInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') globalSearchBtn.click(); });
    sendChatBtn.addEventListener('click', handleSend);
    chatInputField.addEventListener('keypress', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend(); } });
    function getMenuTopicMessage(menuName) {
      const map = {
        'visao': '📌 Visão geral: sou especialista em rotinas WinThor, dependências, banco de dados e fiscal. Escolha um tópico ou descreva seu problema.',
        'rotinas': '🔄 Rotinas: suporte para 300, 500, 560, 801, 814, 2075. Informe qual rotina apresenta erro para análise detalhada.',
        'dependencias': '⚙️ Dependências: abordo WTA, validação de packages, versionamento de objetos e sincronização de ambiente.',
        'banco': '💾 Banco de dados: auxílio com objetos inválidos, PL/SQL, consultas em tabelas críticas e troubleshooting Oracle/PostgreSQL.',
        'fiscal': '🏛️ Fiscal: orientações sobre NF-e, contingência, SEFAZ, erros de doc fiscal e ajustes de regime tributário.',
        'historico': '📜 Histórico: posso revisar interações anteriores. Descreva novamente a dúvida ou erro para retomarmos o diagnóstico.'
      };
      return map[menuName] || 'Selecione uma área para mais detalhes técnicos.';
    }
    menuItems.forEach(item => {
      item.addEventListener('click', () => {
        menuItems.forEach(m => m.classList.remove('active'));
        item.classList.add('active');
        const menuValue = item.getAttribute('data-menu');
        sendToBackend(getMenuTopicMessage(menuValue), null);
      });
    });
    function getModuleMessage(moduleTitle) {
      switch(moduleTitle) {
        case 'Rotinas': return '📂 Módulo Rotinas: acesse consultas sobre 300, 500, 560, 801, 814, 2075. Gostaria de detalhes sobre alguma rotina específica?';
        case 'Atualizações': return '🔄 Módulo Atualizações: validação de dependências, WTA, packages e sincronizações. Qual ambiente ou versão você está enfrentando problemas?';
        case 'Banco de Dados': return '🗃️ Módulo Banco de Dados: suporte para objetos inválidos, PL/SQL, tabelas e validações. Envie o erro do banco para eu ajudar.';
        case 'Fiscal': return '📑 Módulo Fiscal: atuação em DocFiscal, NF-e, contingência e SEFAZ. Relate o erro operacional para diagnóstico preciso.';
        default: return 'Este módulo fornece suporte técnico específico. Descreva sua necessidade.';
      }
    }
    moduleBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const card = btn.closest('.moduleCard');
        const title = card.querySelector('h3')?.innerText || 'Módulo';
        sendToBackend(getModuleMessage(title), null);
      });
    });
    openAtendimento.addEventListener('click', () => { sendToBackend("Preciso de atendimento humano para resolver um problema técnico.", null); });
  })();
</script>
</body>
</html>
"""

@app.route('/')
def index():
    return render_template_string(HTML_TEMPLATE)

@app.route('/chat', methods=['POST'])
def chat():
    try:
        data = request.json
        mensagem = data.get('mensagem', '')
        imagem_base64 = data.get('imagem', None)

        texto_extraido = ""
        if imagem_base64:
            if ',' in imagem_base64:
                imagem_base64 = imagem_base64.split(',')[1]
            try:
                imagem_bytes = base64.b64decode(imagem_base64)
                texto_extraido = analisar_imagem_rotina(imagem_bytes)
            except:
                pass

        pergunta_completa = f"{mensagem}\n\n{texto_extraido}" if texto_extraido else mensagem
        resposta = responder(pergunta_completa)
        return jsonify({'resposta': str(resposta)})
    except Exception as e:
        return jsonify({'resposta': f"❌ Erro: {str(e)}"})

if __name__ == '__main__':
    print("=" * 60)
    print(f"🌐 WinThor IA | 📂 Módulos: {len(modulos_carregados)} | 🛠️ Erros: {len(erros_lista)}")
    print("🚀 http://localhost:5000")
    print("=" * 60)
    app.run(host='0.0.0.0', port=5000, debug=True, use_reloader=False)
