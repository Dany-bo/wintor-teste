import ollama
import json
import os
import re
from PIL import Image
import base64
from io import BytesIO
import numpy as np
import easyocr
from flask import Flask, request, jsonify, render_template_string
import traceback
from datetime import datetime
import logging
import random

# ==================================================
# CONFIGURAÇÕES INICIAIS
# ==================================================
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)

ocr_reader = easyocr.Reader(['pt', 'en'], gpu=False)
MODELO_LLM = "qwen2.5:14b"  # Modelo atualizado

# ==================================================
# CARREGAR MÓDULOS DE ROTINAS (modulo_*.json)
# ==================================================
rotinas_dict = {}
modulos_carregados = []

for arquivo in os.listdir("."):
    if arquivo.lower().startswith("modulo_") and arquivo.endswith(".json"):
        try:
            with open(arquivo, "r", encoding='utf-8') as f:
                modulo = json.load(f)
            dados_modulo = modulo["modulo"]
            nome_modulo = dados_modulo["nome"]
            rotinas = dados_modulo["rotinas"]
            for rotina in rotinas:
                codigo = rotina["codigo"]
                rotinas_dict[codigo] = {
                    "nome": rotina["nome"],
                    "explicacao": rotina.get("explicacao", "Explicação não informada."),
                    "proxima": rotina.get("proxima_rotina_sugerida", "Nenhuma"),
                    "dependencias": rotina.get("dependencias", []),
                    "modulo": nome_modulo
                }
            modulos_carregados.append(nome_modulo)
            print(f"✅ Módulo '{nome_modulo}' carregado com {len(rotinas)} rotinas.")
        except Exception as e:
            print(f"❌ Erro ao ler {arquivo}: {e}")

if not rotinas_dict:
    print("⚠️ Nenhuma rotina encontrada. Coloque arquivos 'modulo_*.json' na pasta.")
    exit(1)

print(f"\n📚 Total de rotinas carregadas: {len(rotinas_dict)}")

# ==================================================
# CARREGAR BASE DE ERROS (erros_wintor.json)
# ==================================================
erros_lista = []
if os.path.exists("erros_wintor.json"):
    try:
        with open("erros_wintor.json", "r", encoding='utf-8') as f:
            erros_lista = json.load(f).get("erros", [])
        print(f"✅ Carregados {len(erros_lista)} erros/soluções.")
    except Exception as e:
        print(f"⚠️ Erro ao carregar erros_wintor.json: {e}")
else:
    print("ℹ️ Arquivo erros_wintor.json não encontrado. Apenas rotinas serão usadas.")

# ==================================================
# FUNÇÕES AUXILIARES
# ==================================================
def extrair_numero_rotina(texto):
    padroes = [
        r'\b(?:rotina|código|codigo|numero|número|me dê a|mostre a|qual a|a rotina|fala da|explique a|o que é a|sobre a|consulte a|pesquise a)\s*(\d{3,4})\b',
        r'\b(\d{3,4})\b'
    ]
    for padrao in padroes:
        match = re.search(padrao, texto, re.IGNORECASE)
        if match:
            return int(match.group(1))
    return None

def rotinas_proximas(codigo, limite=5):
    codigos = sorted(rotinas_dict.keys())
    if codigo in codigos:
        return []
    pos = 0
    for i, c in enumerate(codigos):
        if c > codigo:
            pos = i
            break
    return codigos[max(0, pos-limite//2):pos+limite//2]

def extrair_texto_imagem_bytes(imagem_bytes):
    try:
        imagem = Image.open(BytesIO(imagem_bytes))
        imagem.thumbnail((800, 800))
        imagem_np = np.array(imagem)
        resultado = ocr_reader.readtext(imagem_np, detail=0, paragraph=True)
        texto = " ".join(resultado)
        return texto.strip()
    except Exception as e:
        print(f"Erro OCR: {traceback.format_exc()}")
        return f"Erro ao processar imagem: {e}"

def detectar_erro(texto):
    """Verifica se a pergunta corresponde a algum erro conhecido (por palavras-chave)."""
    texto_lower = texto.lower()
    for erro in erros_lista:
        for palavra in erro.get("palavras_chave", []):
            if palavra.lower() in texto_lower:
                return erro
    return None

# ==================================================
# SISTEMA DE APRENDIZADO CONTÍNUO
# ==================================================
historico_conversa = []
ARQUIVO_APRENDIZADO = "aprendizado_ia.json"

def salvar_aprendizado(pergunta, resposta, categoria):
    """Salva interações para aprendizado futuro"""
    try:
        aprendizado = []
        if os.path.exists(ARQUIVO_APRENDIZADO):
            with open(ARQUIVO_APRENDIZADO, 'r', encoding='utf-8') as f:
                aprendizado = json.load(f)
        
        aprendizado.append({
            "data": datetime.now().isoformat(),
            "categoria": categoria,
            "pergunta": pergunta[:500],
            "resposta": resposta[:1000],
            "feedback": None
        })
        
        if len(aprendizado) > 1000:
            aprendizado = aprendizado[-1000:]
        
        with open(ARQUIVO_APRENDIZADO, 'w', encoding='utf-8') as f:
            json.dump(aprendizado, f, indent=2, ensure_ascii=False)
            
        logger.info("📝 Aprendizado registrado")
    except Exception as e:
        logger.error(f"Erro ao salvar aprendizado: {e}")

def buscar_historico_similar(pergunta):
    """Busca respostas anteriores similares para aprendizado"""
    try:
        if not os.path.exists(ARQUIVO_APRENDIZADO):
            return None
        
        with open(ARQUIVO_APRENDIZADO, 'r', encoding='utf-8') as f:
            aprendizado = json.load(f)
        
        termos_pergunta = set(pergunta.lower().split())
        for item in reversed(aprendizado[-50:]):
            termos_item = set(item['pergunta'].lower().split())
            if len(termos_pergunta & termos_item) > 3:
                return item['resposta']
        return None
    except:
        return None

def analisar_imagem_rotina(imagem_bytes):
    """Análise especializada para imagens de telas do WinThor"""
    texto_extraido = extrair_texto_imagem_bytes(imagem_bytes)
    
    numero_rotina = extrair_numero_rotina(texto_extraido)
    if numero_rotina and numero_rotina in rotinas_dict:
        info = rotinas_dict[numero_rotina]
        return f"[Imagem da Rotina {numero_rotina} - {info['nome']}]\n\nConteúdo da tela:\n{texto_extraido[:500]}"
    
    return f"[Imagem de tela do WinThor]\n\nConteúdo identificado:\n{texto_extraido[:500]}"

# ==================================================
# FUNÇÃO PRINCIPAL DE RESPOSTA (OTIMIZADA)
# ==================================================
def responder(pergunta_usuario):
    if not pergunta_usuario:
        return "Olá! Como posso ajudar? Pergunte sobre rotinas WinThor, erros ou envie uma imagem. 😊"

    # Registra no histórico da conversa atual
    historico_conversa.append({
        "timestamp": datetime.now().isoformat(),
        "pergunta": pergunta_usuario[:200],
        "contexto": "inicio"
    })
    
    p_lower = pergunta_usuario.lower().strip()
    palavras = p_lower.split()
    
    # ==================================================
    # SISTEMA DE CONTEXTO - ENTENDE A CONVERSA
    # ==================================================
    
    # Pega o último contexto da conversa
    contexto_atual = "inicio"
    if len(historico_conversa) >= 2:
        contexto_atual = historico_conversa[-2].get("contexto", "inicio")
    
    # Detecta se a pergunta tem assunto técnico
    tem_assunto_tecnico = False
    palavras_tecnicas = ['rotina', 'erro', 'problema', 'como', 'qual', 'onde', 'quando', 
                         'pedido', 'compra', 'venda', 'estoque', 'fiscal', 'nota', 'nf',
                         'cadastro', 'ajuda', 'explica', 'digitar', 'lançar', 'sistema',
                         'módulo', 'tela', 'campo', 'código', 'fornecedor', 'cliente']
    
    for palavra in palavras:
        if palavra in palavras_tecnicas:
            tem_assunto_tecnico = True
            break
    
    # Detecta se mencionou número de rotina
    tem_numero_rotina = extrair_numero_rotina(pergunta_usuario) is not None
    
    # ==================================================
    # RESPOSTAS NATURAIS COM CONTEXTO
    # ==================================================
    
    # SITUAÇÃO 1: SAUDAÇÃO PURA (só "oi", sem assunto técnico)
    if any(p_lower == s for s in ['oi', 'ola', 'olá', 'hey', 'eai', 'e aí']) and not tem_assunto_tecnico:
        historico_conversa[-1]["contexto"] = "saudacao"
        respostas = [
            "Oi! 😊 Tudo bem?",
            "Olá! Como vai?",
            "Oi! Que bom falar com você!",
            "Olá! Em que posso ajudar?"
        ]
        return random.choice(respostas)
    
    # SITUAÇÃO 2: SAUDAÇÃO + PERGUNTA TÉCNICA (ex: "Oi, como usar rotina 220?")
    if any(s in palavras for s in ['oi', 'ola', 'olá']) and tem_assunto_tecnico:
        historico_conversa[-1]["contexto"] = "tecnico"
        respostas = [
            "Olá! 😊 Vamos ver isso...",
            "Oi! Deixa eu te ajudar com isso...",
            "Olá! Vou pesquisar sobre isso para você...",
        ]
        # Remove a saudação e processa a pergunta técnica
        pergunta_limpa = ' '.join([p for p in palavras if p not in ['oi', 'ola', 'olá']])
        if pergunta_limpa:
            return random.choice(respostas) + "\n\n" + processar_pergunta_tecnica(pergunta_limpa)
    
    # SITUAÇÃO 3: SAUDAÇÃO + "TUDO BEM" (conversa social)
    if any(s in p_lower for s in ['tudo bem', 'como vai', 'como está']) and not tem_assunto_tecnico:
        historico_conversa[-1]["contexto"] = "social"
        # Verifica se é resposta a um "tudo bem" anterior
        if contexto_atual == "saudacao":
            respostas = [
                "Tudo bem sim! 😊 No que posso ajudar com o WinThor?",
                "Estou bem! Obrigado por perguntar. Tem alguma dúvida sobre o sistema?",
                "Vou bem! Em que posso ser útil hoje?"
            ]
        else:
            respostas = [
                "Tudo bem sim! 😊 E você?",
                "Estou ótimo! Como está você?",
                "Tudo certo! O que me conta?"
            ]
        return random.choice(respostas)
    
    # SITUAÇÃO 4: AGRADECIMENTO (depende do contexto anterior)
    if any(a in p_lower for a in ['obrigado', 'obrigada', 'valeu', 'brigado']) and len(p_lower) < 30:
        if contexto_atual == "tecnico" or contexto_atual == "rotina":
            respostas = [
                "De nada! 😊 Conseguiu resolver? Se precisar de mais ajuda, é só chamar!",
                "Por nada! Qualquer outra dúvida sobre essa rotina, estou aqui!",
                "Imagina! Precisando, pode me perguntar mais sobre o WinThor!"
            ]
        elif contexto_atual == "saudacao" or contexto_atual == "social":
            respostas = [
                "De nada! 😊 Como posso ajudar com o WinThor?",
                "Por nada! Tem alguma dúvida sobre o sistema hoje?",
                "Não há de quê! No que posso ser útil?"
            ]
        else:
            respostas = [
                "De nada! 😊 Estou aqui para ajudar!",
                "Por nada! Precisando, é só perguntar!",
                "Imagina! 😊"
            ]
        historico_conversa[-1]["contexto"] = "agradecimento"
        return random.choice(respostas)
    
    # SITUAÇÃO 5: PERGUNTA TÉCNICA DIRETA (sem saudação)
    if tem_assunto_tecnico or tem_numero_rotina:
        historico_conversa[-1]["contexto"] = "tecnico"
        return processar_pergunta_tecnica(pergunta_usuario)
    
    # SITUAÇÃO 6: FRASE MUITO CURTA SEM SENTIDO
    if len(palavras) < 3:
        historico_conversa[-1]["contexto"] = "duvida"
        respostas = [
            "🤔 Não entendi bem. Pode me explicar melhor o que precisa?",
            "Fiquei na dúvida. Tem alguma pergunta sobre o WinThor?",
            "Desculpe, não compreendi. Pode me dar mais detalhes?"
        ]
        return random.choice(respostas)
    
    # SITUAÇÃO 7: NADA ESPECÍFICO - pergunta genérica
    historico_conversa[-1]["contexto"] = "generico"
    return "🤔 Não encontrei nada específico sobre isso nos módulos do WinThor.\n\nTente:\n• Informar o número da rotina (ex: '220')\n• Descrever qual módulo (Compra, Venda, Estoque...)\n• Enviar uma imagem da tela\n\nAssim consigo ajudar melhor! 📚"


# ==================================================
# FUNÇÃO AUXILIAR: Processa perguntas técnicas
# ==================================================
def processar_pergunta_tecnica(pergunta):
    """Processa perguntas sobre rotinas e erros (código existente)"""
    
    # Verifica cache de histórico
    cache = buscar_historico_similar(pergunta)
    if cache:
        logger.info("📚 Resposta do histórico")
        return cache + "\n\n_(Baseado em conversas anteriores)_"
    
    # PRIORIDADE 1: Erro conhecido
    erro = detectar_erro(pergunta)
    if erro:
        resposta = f"🔍 **Problema identificado:** {erro.get('titulo', 'Erro')}\n\n"
        resposta += f"**Causa:** {erro.get('causa', 'Não informada')}\n\n"
        resposta += f"**Solução:**\n{erro.get('solucao', 'Consulte o manual')}\n\n"
        if erro.get('proximo_passo_sugerido'):
            resposta += f"**👣 Próximo passo:** {erro['proximo_passo_sugerido']}"
        salvar_aprendizado(pergunta, resposta, "erro")
        return resposta

    # PRIORIDADE 2: Número de rotina
    codigo = extrair_numero_rotina(pergunta)

    if codigo and codigo in rotinas_dict:
        info = rotinas_dict[codigo]
        
        resposta = f"📂 **Rotina {codigo} - {info['nome']}**\n"
        resposta += f"📌 Módulo: {info['modulo']}\n\n"
        resposta += f"**📝 Explicação:**\n{info['explicacao']}\n\n"
        
        if info['dependencias']:
            resposta += f"**🔗 Dependências:** {', '.join(map(str, info['dependencias']))}\n"
        if info['proxima'] != 'Nenhuma':
            resposta += f"**👉 Próxima rotina:** {info['proxima']}\n"
        
        resposta += f"\n💡 Tem alguma dúvida específica sobre essa rotina? Posso ajudar!"
        salvar_aprendizado(pergunta, resposta, f"rotina_{codigo}")
        return resposta

    elif codigo:
        proximos = rotinas_proximas(codigo)
        sugestao = f"Rotinas próximas: {', '.join(map(str, proximos[:5]))}" if proximos else ""
        return f"🤔 Rotina {codigo} não encontrada nos módulos.\n\n{sugestao}"

    # PRIORIDADE 3: Busca textual
    termos = set(re.findall(r'\b\w{3,}\b', pergunta.lower()))
    candidatos = []
    for cod, info in rotinas_dict.items():
        texto_busca = f"{info['nome']} {info['explicacao']}".lower()
        pontuacao = sum(1 for termo in termos if termo in texto_busca)
        if pontuacao > 0:
            candidatos.append((cod, info, pontuacao))
    
    candidatos.sort(key=lambda x: x[2], reverse=True)

    if candidatos:
        resposta = "🔍 **Rotinas relacionadas:**\n\n"
        for cod, info, _ in candidatos[:5]:
            resposta += f"📌 **{cod} - {info['nome']}**\n"
            resposta += f"   📂 Módulo: {info['modulo']}\n"
            resposta += f"   📝 {info['explicacao'][:200]}...\n\n"
        resposta += "Qual dessas se encaixa no que você precisa? Me diga o número! 😊"
        salvar_aprendizado(pergunta, resposta, "consulta")
        return resposta
    
    # Se não encontrou nada específico
    return "Não encontrei uma rotina específica para isso. Poderia me dar mais detalhes ou o número da rotina?"

    # Verifica cache de histórico
    cache = buscar_historico_similar(pergunta_usuario)
    if cache:
        logger.info("📚 Resposta do histórico")
        return cache + "\n\n_(Baseado em conversas anteriores)_"
    
    # Verifica cache de histórico
    cache = buscar_historico_similar(pergunta_usuario)
    if cache:
        logger.info("📚 Resposta encontrada no histórico")
        return cache + "\n\n_(Baseado em conversas anteriores)_"
    
    # PRIORIDADE 1: Erro conhecido
    erro = detectar_erro(pergunta_usuario)
    if erro:
        resposta = f"🔍 **Problema identificado:** {erro.get('titulo', 'Erro')}\n\n"
        resposta += f"**Causa:** {erro.get('causa', 'Não informada')}\n\n"
        resposta += f"**Solução:**\n{erro.get('solucao', 'Consulte o manual')}\n\n"
        if erro.get('proximo_passo_sugerido'):
            resposta += f"**👣 Próximo passo:** {erro['proximo_passo_sugerido']}"
        salvar_aprendizado(pergunta_usuario, resposta, "erro")
        return resposta

    try:
        codigo = extrair_numero_rotina(pergunta_usuario)

        # PRIORIDADE 2: Número de rotina específico
        if codigo and codigo in rotinas_dict:
            info = rotinas_dict[codigo]
            
            # Resposta direta + IA para complementar
            base = f"📂 **Rotina {codigo} - {info['nome']}**\n"
            base += f"Módulo: {info['modulo']}\n\n"
            base += f"{info['explicacao']}\n\n"
            if info['dependencias']:
                base += f"**Dependências:** {', '.join(map(str, info['dependencias']))}\n"
            if info['proxima'] != 'Nenhuma':
                base += f"**Próxima rotina:** {info['proxima']}\n"
            
            # Se pergunta é simples (só número), retorna direto
            if len(pergunta_usuario.split()) <= 3:
                base += "\nTem alguma dúvida específica sobre essa rotina? Posso detalhar mais! 😊"
                salvar_aprendizado(pergunta_usuario, base, f"rotina_{codigo}")
                return base
            
            # Se pergunta é complexa, usa IA para complementar
            prompt = f"""Dados da rotina:
{codigo} - {info['nome']}
{info['explicacao']}

Usuário perguntou: {pergunta_usuario}

Responda de forma conversacional e objetiva (máximo 4 linhas)."""
            resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 200})
            resposta_final = base + "\n" + resposta_ia['response']
            salvar_aprendizado(pergunta_usuario, resposta_final, f"rotina_{codigo}")
            return resposta_final

        elif codigo:
            proximos = rotinas_proximas(codigo)
            sugestao = f"Rotinas próximas: {', '.join(map(str, proximos[:5]))}" if proximos else ""
            return f"🤔 Rotina {codigo} não encontrada.\n\n{sugestao}\n\nSe souber o que faz, me explique que eu aprendo! 📚"

        # PRIORIDADE 3: Busca textual
        termos = set(re.findall(r'\b\w{3,}\b', p_lower))
        candidatos = []
        for cod, info in rotinas_dict.items():
            texto_busca = f"{info['nome']} {info['explicacao']}".lower()
            pontuacao = sum(1 for termo in termos if termo in texto_busca)
            if pontuacao > 0:
                candidatos.append((cod, info, pontuacao))
        
        candidatos.sort(key=lambda x: x[2], reverse=True)

        if candidatos:
            # Se muitos candidatos, usa IA
            if len(candidatos) > 3:
                contexto = ""
                for cod, info, _ in candidatos[:5]:
                    contexto += f"📌 {cod} - {info['nome']}: {info['explicacao'][:100]}...\n"
                
                prompt = f"""Rotinas encontradas:
{contexto}

Usuário: {pergunta_usuario}

Responda de forma curta (3-4 linhas) indicando a melhor rotina."""
                resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 150})
                resposta_final = resposta_ia['response']
            else:
                # Poucos candidatos, resposta direta
                resposta_final = "Encontrei essas rotinas:\n\n"
                for cod, info, _ in candidatos[:3]:
                    resposta_final += f"📌 **{cod} - {info['nome']}**\n{info['explicacao'][:200]}...\n\n"
                resposta_final += "Qual delas se encaixa no que precisa?"
            
            salvar_aprendizado(pergunta_usuario, resposta_final, "consulta")
            return resposta_final
        
        # Se não encontrou nada, usa IA para responder de forma genérica
        prompt = f"""Usuário do sistema WinThor perguntou: {pergunta_usuario}

Responda de forma educada e curta (2-3 linhas), explicando que pode ajudar com rotinas, erros e dúvidas do sistema."""
        resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.7, "num_predict": 100})
        return resposta_ia['response']

    except Exception as e:
        logger.error(f"Erro: {e}")
        return f"❌ Ops! Erro: {str(e)}. Verifique se o Ollama está rodando com: ollama serve"

# ==================================================
# SERVIDOR FLASK COM INTERFACE WEB
# ==================================================
app = Flask(__name__)
app.config['MAX_CONTENT_LENGTH'] = 16 * 1024 * 1024

