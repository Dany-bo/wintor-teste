ocr_reader = easyocr.Reader(['pt', 'en'], gpu=False)
MODELO_LLM = "qwen2.5:14b"

# ==================================================
# CARREGAR MÓDULOS DE ROTINAS
# ==================================================
rotinas_dict = {}
modulos_carregados = []

for arquivo in os.listdir("."):
