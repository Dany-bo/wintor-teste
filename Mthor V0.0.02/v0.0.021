# ==================================================
# FUNÇÕES AUXILIARES
# ==================================================
def extrair_numero_rotina(texto):
    padroes = [
        r'\b(?:rotina|código|codigo|numero|número|me dê a|mostre a|qual a|a rotina|fala da|explique a|o que é a|sobre a|consulte a|pesquise a)\s*(\d{3,4})\b',
        r'\b(\d{3,4})\b'
    ]
    for padrao in padroes:
        match = re.search(padrao, texto, re.IGNORECASE)
        if match:
            return int(match.group(1))
    return None

def rotinas_proximas(codigo, limite=5):
    codigos = sorted(rotinas_dict.keys())
    if codigo in codigos:
        return []
    pos = 0
    for i, c in enumerate(codigos):
        if c > codigo:
            pos = i
            break
    return codigos[max(0, pos-limite//2):pos+limite//2]

def extrair_texto_imagem_bytes(imagem_bytes):
    try:
        imagem = Image.open(BytesIO(imagem_bytes))
        imagem.thumbnail((800, 800))
        imagem_np = np.array(imagem)
        resultado = ocr_reader.readtext(imagem_np, detail=0, paragraph=True)
        texto = " ".join(resultado)
        return texto.strip()
    except:
        return ""

def detectar_erro(texto):
    """Só detecta erro se NÃO for uma pergunta sobre rotina"""
    # Se a pessoa está perguntando sobre uma rotina, NÃO é erro
    palavras_pergunta = ['duvida', 'dúvida', 'como', 'oque', 'o que', 'explica', 'ensina', 'ajuda', 'saber', 'entender']
    if any(p in texto.lower() for p in palavras_pergunta):
        return None
    
    texto_lower = texto.lower()
    for erro in erros_lista:
        palavras = erro.get("palavras_chave", [])
        for p in palavras:
            if p.startswith("ORA-") and p.lower() in texto_lower:
                return formatar_resposta_erro(erro, texto)
    
    melhor_erro = None
    melhor_pontuacao = 0
    for erro in erros_lista:
        palavras = erro.get("palavras_chave", [])
        pontuacao = sum(len(p) for p in palavras if p.lower() in texto_lower)
        codigos = erro.get("codigos_rotina_relacionados", [])
        pontuacao += sum(50 for c in codigos if str(c) in texto_lower)
        if pontuacao > melhor_pontuacao:
            melhor_pontuacao = pontuacao
            melhor_erro = erro
    
    if melhor_pontuacao >= 6:
        return formatar_resposta_erro(melhor_erro, texto)
    return None

def formatar_resposta_erro(erro, pergunta_original):
    pergunta_lower = pergunta_original.lower()
    
    if any(p in pergunta_lower for p in ['socorro', 'urgente', 'parou']):
        abertura = random.choice(["😰 Calma, vamos resolver! Já vi esse erro...", "Respira fundo! 😊 Tem solução:"])
    elif '[ERRO DETECTADO' in pergunta_original:
        abertura = random.choice(["📸 Pela imagem, identifiquei o erro!", "Analisei a imagem e já sei o que é! 😊"])
    else:
        abertura = random.choice(["🔍 Encontrei algo:", "Hummm, esse erro é conhecido!", "Já vi isso acontecer!"])
    
    resposta = f"{abertura}\n\n📌 **{erro.get('titulo')}**\n\n"
    resposta += f"🧠 **Por que acontece:**\n{erro.get('causa')}\n\n"
    resposta += f"✅ **Como resolver:**\n{erro.get('solucao')}\n\n"
    
    codigos = erro.get("codigos_rotina_relacionados", [])
    if codigos:
        resposta += f"🔗 **Rotinas úteis:** {', '.join(map(str, codigos))}\n\n"
    if erro.get('proximo_passo_sugerido'):
        resposta += f"👣 **Sugiro:** {erro['proximo_passo_sugerido']}\n\n"
    
    resposta += random.choice(["Conseguiu entender? 😊", "Ficou alguma dúvida?", "Depois me conta se deu certo!"])
    return resposta

def analisar_imagem_rotina(imagem_bytes):
    texto_extraido = extrair_texto_imagem_bytes(imagem_bytes)
    if not texto_extraido or len(texto_extraido) < 5:
        return "[Imagem enviada - qualidade baixa]"
    
    palavras_erro = ['erro', 'atenção', 'falha', 'ORA-', 'mensagem', 'banco de dados', 'identificador inválido']
    eh_erro = any(p in texto_extraido.lower() for p in palavras_erro)
    numero_rotina = extrair_numero_rotina(texto_extraido)
    
    if eh_erro:
        resultado = f"[ERRO DETECTADO EM IMAGEM]\n\n{texto_extraido[:800]}"
        if numero_rotina:
            resultado += f"\n\n📌 Rotina mencionada: {numero_rotina}"
        return resultado
    
    if numero_rotina and numero_rotina in rotinas_dict:
        info = rotinas_dict[numero_rotina]
        return f"[Imagem da Rotina {numero_rotina} - {info['nome']}]\n\nConteúdo:\n{texto_extraido[:500]}"
    
    return f"[Imagem de tela WinThor]\n\nConteúdo:\n{texto_extraido[:500]}"

# ==================================================
# SISTEMA DE APRENDIZADO
# ==================================================
historico_conversa = []

def salvar_aprendizado(pergunta, resposta, categoria):
    try:
        aprendizado_memorias.append({
            "data": datetime.now().isoformat(),
            "categoria": categoria,
            "pergunta": pergunta[:500],
            "resposta": str(resposta)[:1000],
            "feedback": None
        })
        if len(aprendizado_memorias) > 500:
            aprendizado_memorias.pop(0)
        with open(ARQUIVO_APRENDIZADO, 'w', encoding='utf-8') as f:
            json.dump(aprendizado_memorias, f, indent=2, ensure_ascii=False)
    except:
        pass

def buscar_resposta_memorizada(pergunta):
    p_lower = pergunta.lower().strip()
    for item in reversed(aprendizado_memorias):
        if item.get('feedback') == 'negativo':
            continue
        if item.get('pergunta', '').lower().strip() == p_lower and item.get('resposta'):
            return item['resposta']
    return None

# ==================================================
# FUNÇÃO PRINCIPAL
# ==================================================
def responder(pergunta_usuario):
    if not pergunta_usuario:
        return "Olá! Como posso ajudar? Pergunte sobre rotinas WinThor, erros ou envie uma imagem. 😊"

    historico_conversa.append({
        "timestamp": datetime.now().isoformat(),
        "pergunta": pergunta_usuario[:200],
        "contexto": "inicio"
    })
    
    p_lower = pergunta_usuario.lower().strip()
    palavras = p_lower.split()
    
    contexto_atual = "inicio"
    if len(historico_conversa) >= 2:
        contexto_atual = historico_conversa[-2].get("contexto", "inicio")
    
    tem_assunto_tecnico = False
    palavras_tecnicas = ['rotina', 'erro', 'problema', 'como', 'qual', 'onde', 'quando', 
                         'pedido', 'compra', 'venda', 'estoque', 'fiscal', 'nota', 'nf',
                         'cadastro', 'ajuda', 'explica', 'digitar', 'lançar', 'sistema',
                         'módulo', 'tela', 'campo', 'código', 'fornecedor', 'cliente',
                         'winthor', 'me ajuda', 'duvida', 'dúvida']
    
    for palavra in palavras:
        if palavra in palavras_tecnicas:
            tem_assunto_tecnico = True
            break
    
    tem_numero_rotina = extrair_numero_rotina(pergunta_usuario) is not None
    
    # SAUDAÇÕES
    saudacoes = ['oi', 'ola', 'olá', 'hey', 'eai', 'e aí', 'bom dia', 'boa tarde', 'boa noite']
    social = ['tudo bem', 'como vai', 'como está', 'tudo otimo', 'tudo ótimo', 'tudo certo', 
              'tudo joia', 'tudo e com voce', 'tudo e com você', 'e com voce', 'e com você',
              'tudo bom', 'tudo tranquilo', 'beleza', 'suave', 'de boa']
    agradecimentos = ['obrigado', 'obrigada', 'valeu', 'brigado', 'agradeço']
    
    # SAUDAÇÃO PURA
    if any(s in p_lower for s in saudacoes) and not tem_assunto_tecnico and not tem_numero_rotina and len(palavras) <= 3:
        historico_conversa[-1]["contexto"] = "saudacao"
        if 'bom dia' in p_lower:
            resp = random.choice(["Bom dia! ☀️ Tudo bem? Como posso ajudar?", "Bom dia! 😊 No que posso ser útil hoje?"])
        elif 'boa tarde' in p_lower:
            resp = random.choice(["Boa tarde! 🌤️ Como posso ajudar?", "Boa tarde! 😊 Em que posso ajudar?"])
        elif 'boa noite' in p_lower:
            resp = random.choice(["Boa noite! 🌙 Como posso ajudar com o WinThor?", "Boa noite! 😊 No que posso ser útil?"])
        else:
            resp = random.choice(["Oi! 😊 Tudo bem?", "Olá! Que bom falar com você!", "Oi! Como vai?", "Olá! Em que posso ajudar?"])
        return resp
    
    # SAUDAÇÃO + TÉCNICO
    if any(s in p_lower for s in saudacoes) and (tem_assunto_tecnico or tem_numero_rotina):
        historico_conversa[-1]["contexto"] = "tecnico"
        abertura = random.choice(["Olá! 😊 Vamos ver isso...", "Oi! Deixa eu te ajudar...", "Olá! Vou pesquisar sobre isso..."])
        pergunta_limpa = ' '.join([p for p in palavras if p.lower() not in saudacoes])
        if pergunta_limpa:
            return abertura + "\n\n" + processar_pergunta_tecnica(pergunta_limpa)
        return abertura + "\n\n" + processar_pergunta_tecnica(pergunta_usuario)
    
    # SOCIAL
    if any(s in p_lower for s in social) and not tem_assunto_tecnico and not tem_numero_rotina and len(palavras) <= 6:
        historico_conversa[-1]["contexto"] = "social"
        if 'tudo otimo' in p_lower or 'tudo ótimo' in p_lower:
            resp = random.choice(["Que bom! 😊 Fico feliz! No que posso ajudar com o WinThor?", "Ótimo saber! 😊 Em que posso ajudar hoje?"])
        elif 'tudo bem' in p_lower:
            if contexto_atual == "saudacao":
                resp = random.choice(["Tudo bem sim! 😊 No que posso ajudar?", "Estou bem! Tem alguma dúvida sobre o sistema?"])
            else:
                resp = random.choice(["Tudo bem sim! 😊 E você?", "Estou ótimo! E você?"])
        else:
            resp = random.choice(["Vou bem! Obrigado por perguntar. 😊", "Estou bem! Em que posso ajudar?"])
        return resp
    
    # AGRADECIMENTO
    if any(a in p_lower for a in agradecimentos) and len(palavras) <= 4:
        historico_conversa[-1]["contexto"] = "agradecimento"
        if 'valeu' in p_lower:
            resp = random.choice(["Valeu você! 😊 Precisando, estou aqui!", "Tamo junto! 🤝"])
        else:
            resp = random.choice(["De nada! 😊 Precisando, é só chamar!", "Por nada! Estou aqui para ajudar!", "Imagina! 😊"])
        return resp
    
    # TÉCNICO
    if tem_assunto_tecnico or tem_numero_rotina:
        historico_conversa[-1]["contexto"] = "tecnico"
        return processar_pergunta_tecnica(pergunta_usuario)
    
    # FRASE CURTA
    if len(palavras) <= 3:
        historico_conversa[-1]["contexto"] = "duvida"
        return random.choice([
            "🤔 Não entendi bem. Pode me explicar melhor?",
            "Fiquei na dúvida. Tem alguma pergunta sobre o WinThor?",
            "Desculpe, não compreendi. Pode me dar mais detalhes?"
        ])
    
    # NADA ENCONTRADO
    historico_conversa[-1]["contexto"] = "generico"
    return "🤔 Não encontrei nada específico sobre isso nos módulos do WinThor.\n\nTente:\n• Informar o número da rotina (ex: '220')\n• Descrever qual módulo (Compra, Venda, Estoque...)\n• Enviar uma imagem da tela\n\nAssim consigo ajudar melhor! 📚"


# ==================================================
# PROCESSAR PERGUNTA TÉCNICA
# ==================================================
def processar_pergunta_tecnica(pergunta):
    """Processa perguntas sobre rotinas e erros"""
    
    cache = buscar_resposta_memorizada(pergunta)
    if cache:
        return cache + "\n\n_(Baseado em conversas anteriores)_"
    
    # Busca contexto
    rotina_contexto = None
    for item in reversed(historico_conversa):
        perg = item.get("pergunta", "")
        rot = extrair_numero_rotina(perg)
        if rot:
            rotina_contexto = rot
            break
    
    codigo_atual = extrair_numero_rotina(pergunta)
    
    # Se tem número de rotina na pergunta, SEMPRE prioriza a rotina
    if codigo_atual:
        # Primeiro verifica tutorial
        if codigo_atual in tutoriais_dict:
            return formatar_tutorial(tutoriais_dict[codigo_atual], pergunta)
        
        # Depois rotina normal
        if codigo_atual in rotinas_dict:
            info = rotinas_dict[codigo_atual]
            resp = f"📂 **Rotina {codigo_atual} - {info['nome']}**\n"
            resp += f"📌 Módulo: {info['modulo']}\n\n"
            resp += f"**📝 O que faz:**\n{info['explicacao']}\n\n"
            if info['dependencias']:
                resp += f"**🔗 Dependências:** {', '.join(map(str, info['dependencias']))}\n"
            if info['proxima'] != 'Nenhuma':
                resp += f"**👉 Próxima rotina:** {info['proxima']}\n"
            resp += f"\n💡 Quer saber o passo a passo? Pergunte: 'como usar a rotina {codigo_atual}'! 😊"
            salvar_aprendizado(pergunta, resp, f"rotina_{codigo_atual}")
            return resp
        else:
            proximos = rotinas_proximas(codigo_atual)
            sugestao = f"Rotinas próximas: {', '.join(map(str, proximos[:5]))}" if proximos else ""
            return f"🤔 Rotina {codigo_atual} não encontrada.\n\n{sugestao}"
    
    # Continuação de contexto (sem número, mas tem rotina anterior)
    if not codigo_atual and rotina_contexto:
        palavras_continuacao = ['como', 'onde', 'qual', 'gerar', 'fazer', 'criar', 'lançar', 
                                'digitar', 'emitir', 'passo', 'etapa', 'explica', 'detalhe',
                                'ensina', 'ajuda', 'exemplo', 'procurar', 'achar', 'encontrar',
                                'localizar', 'imprimir', 'danfe', 'pdf', 'xml', 'duvida', 'dúvida']
        
        if any(p in pergunta.lower().split() for p in palavras_continuacao):
            if rotina_contexto in tutoriais_dict:
                return formatar_tutorial(tutoriais_dict[rotina_contexto], pergunta)
            if rotina_contexto in rotinas_dict:
                return formatar_resposta_contexto(rotina_contexto, rotinas_dict[rotina_contexto], pergunta)
    
    # Só verifica erro se não tem número de rotina
    if not codigo_atual:
        erro = detectar_erro(pergunta)
        if erro:
            salvar_aprendizado(pergunta, erro, "erro")
            return erro

    # Busca textual
    termos = set(re.findall(r'\b\w{3,}\b', pergunta.lower()))
    
    for cod, tutorial in tutoriais_dict.items():
        texto_busca = f"{tutorial['titulo']} {tutorial['descricao_curta']} {' '.join(tutorial.get('termos_busca', []))}".lower()
        pontuacao = sum(1 for t in termos if t in texto_busca)
        if pontuacao >= 2:
            return formatar_tutorial(tutorial, pergunta)
    
    candidatos = []
    for cod, info in rotinas_dict.items():
        texto_busca = f"{info['nome']} {info['explicacao']}".lower()
        pontuacao = sum(1 for t in termos if t in texto_busca)
        if pontuacao > 0:
            candidatos.append((cod, info, pontuacao))
    
    candidatos.sort(key=lambda x: x[2], reverse=True)

    if candidatos:
        resp = "🔍 **Rotinas relacionadas:**\n\n"
        for cod, info, _ in candidatos[:5]:
            tem_tutorial = "📚" if cod in tutoriais_dict else "📝"
            resp += f"{tem_tutorial} **{cod} - {info['nome']}**\n"
            resp += f"   📂 {info['modulo']}\n"
            resp += f"   {info['explicacao'][:150]}...\n\n"
        resp += "Qual dessas? Me diga o número! 😊"
        salvar_aprendizado(pergunta, resp, "consulta")
        return resp
    
    return "Não encontrei uma rotina específica. Me dê mais detalhes ou o número da rotina?"


def formatar_tutorial(tutorial, pergunta):
    resp = f"📚 **{tutorial['titulo']}**\n"
    resp += f"📝 _{tutorial['descricao_curta']}_\n\n"
    resp += "**🚶 Passo a passo:**\n"
    for i, passo in enumerate(tutorial['passo_a_passo']):
        resp += f"{i+1}. {passo}\n"
    if tutorial.get('dicas'):
        resp += f"\n**💡 Dicas importantes:**\n"
        for dica in tutorial['dicas']:
            resp += f"• {dica}\n"
    resp += f"\nConseguiu entender? Se tiver dúvida em algum passo, me pergunta! 😊"
    salvar_aprendizado(pergunta, resp, f"tutorial_{tutorial['rotina']}")
    return resp

def formatar_resposta_contexto(codigo, info, pergunta):
    """Resposta quando a pergunta é continuação de uma rotina"""
    resp = f"📂 Sobre a **Rotina {codigo} - {info['nome']}** que estávamos falando:\n\n"
    
    # Tenta usar a IA para responder a pergunta específica
    try:
        prompt = f"""Você é um especialista WinThor. O usuário está com dúvida sobre a rotina {codigo} - {info['nome']}.
        
Dados da rotina:
{info['explicacao']}

Dependências: {', '.join(map(str, info['dependencias'])) if info['dependencias'] else 'Nenhuma'}
Próxima rotina: {info['proxima']}

O usuário perguntou: "{pergunta}"

Responda de forma conversacional e direta (3-5 linhas), focando APENAS no que ele perguntou.
Não repita o tutorial completo. Seja objetivo e útil.
Se não souber a resposta específica, diga "Não tenho essa informação específica, mas posso ajudar com..."."""
        
        resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 200})
        resp += resposta_ia['response']
        resp += f"\n\n💡 Quer o passo a passo completo? Peça 'me ensina a usar a rotina {codigo}'! 😊"
    except:
        # Se falhar, responde com o que tem
        resp += f"📝 **O que a rotina faz:**\n{info['explicacao']}\n\n"
        if info.get('proxima') and info['proxima'] != 'Nenhuma':
            resp += f"📌 **Relacionada:** Rotina {info['proxima']}\n"
        resp += f"\n💡 Para um passo a passo detalhado, peça 'me ensina a usar a rotina {codigo}'! 😊"
    
    salvar_aprendizado(pergunta, resp, f"contexto_{codigo}")
    return resp


def formatar_tutorial(tutorial, pergunta):
    """Formata tutorial - SÓ mostra passo a passo se pedido explícito"""
    
    # Se a pergunta é uma dúvida específica (não pediu passo a passo)
    palavras_tutorial = ['passo a passo', 'como usar', 'como fazer', 'ensina', 'me ensina', 
                         'tutorial', 'como é', 'explica tudo', 'detalhado', 'completo']
    
    if not any(p in pergunta.lower() for p in palavras_tutorial):
        # Responde de forma conversacional, sem o tutorial completo
        resp = f"📂 **{tutorial['titulo']}**\n"
        resp += f"📝 _{tutorial['descricao_curta']}_\n\n"
        
        # Tenta usar IA para responder a dúvida
        try:
            prompt = f"""Especialista WinThor. Dados da rotina:
{tutorial['titulo']}
Passos: {'; '.join(tutorial['passo_a_passo'])}
Dicas: {'; '.join(tutorial.get('dicas', []))}

Usuário perguntou: "{pergunta}"

Responda de forma conversacional (3-5 linhas), focando APENAS na dúvida dele.
Não liste todos os passos. Seja direto e útil."""
            
            resposta_ia = ollama.generate(model=MODELO_LLM, prompt=prompt, options={"temperature": 0.5, "num_predict": 200})
            resp += resposta_ia['response']
            resp += f"\n\n💡 Quer o passo a passo completo? Peça 'me ensina o passo a passo'! 😊"
        except:
            resp += f"**O que você precisa saber:**\n{tutorial['descricao_curta']}\n\n"
            resp += f"💡 Me pergunte 'me ensina o passo a passo' para ver todas as etapas! 😊"
        
        salvar_aprendizado(pergunta, resp, f"tutorial_{tutorial['rotina']}")
        return resp
    
    # Se pediu explicitamente passo a passo, mostra completo
    resp = f"📚 **{tutorial['titulo']}**\n"
    resp += f"📝 _{tutorial['descricao_curta']}_\n\n"
    resp += "**🚶 Passo a passo:**\n"
    for i, passo in enumerate(tutorial['passo_a_passo']):
        resp += f"{i+1}. {passo}\n"
    if tutorial.get('dicas'):
        resp += f"\n**💡 Dicas importantes:**\n"
        for dica in tutorial['dicas']:
            resp += f"• {dica}\n"
    resp += f"\nConseguiu entender? Se tiver dúvida em algum passo, me pergunta! 😊"
    salvar_aprendizado(pergunta, resp, f"tutorial_{tutorial['rotina']}")
    return resp


# ==================================================
# SERVIDOR FLASK
# ==================================================
app = Flask(__name__)
app.config['MAX_CONTENT_LENGTH'] = 16 * 1024 * 1024

