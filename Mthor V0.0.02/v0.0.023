def responder(pergunta_usuario):
    if not pergunta_usuario:
        return "Olá! Como posso ajudar? 😊"

    historico_conversa.append({
        "timestamp": datetime.now().isoformat(),
        "pergunta": pergunta_usuario[:200],
        "contexto": "inicio"
    })
    
    p_lower = pergunta_usuario.lower().strip()
    palavras = p_lower.split()
    
    # ==================================================
    # LIMPEZA DE PONTUAÇÃO E INTERNETÊS
    # ==================================================
    # Remove pontuação para facilitar
    p_limpo = p_lower.replace('?', '').replace('!', '').replace('.', '').replace(',', '')
    
